# ---- Upstash Redis (KV) ----
# Create a database at https://console.upstash.com and copy its REST URL + token.
# On Vercel, the Upstash integration injects these automatically.
KV_REST_API_URL="https://your-db.upstash.io"
KV_REST_API_TOKEN="your-upstash-rest-token"

# ---- Vercel Blob (fund pitch PDFs) ----
# Create a Blob store in your Vercel project (Storage tab). Vercel injects this
# token automatically in deployments. For local dev, run `vercel env pull
# .env.local` to fetch it, or paste a Read/Write token here.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"
